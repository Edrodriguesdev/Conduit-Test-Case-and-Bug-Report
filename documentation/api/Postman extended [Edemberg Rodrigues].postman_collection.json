    {
      "name": "To Create Article",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 or 200\", () => {\r",
              "  pm.expect(pm.response.code).to.be.oneOf([201, 200]);\r",
              "})\r",
              "\r",
              "pm.test(\"Article response body properties check\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.article).to.have.property('slug');\r",
              "    pm.expect(jsonData.article).to.have.property('title');\r",
              "    pm.expect(jsonData.article).to.have.property('body');\r",
              "    pm.expect(jsonData.article).to.have.property('author');\r",
              "});\r",
              "\r",
              "pm.test(\"Slug is present and saved\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    \r",
              "    pm.expect(jsonData.article.slug).to.not.be.empty;\r",
              "    \r",
              "    pm.collectionVariables.set(\"slugConduit\", jsonData.article.slug);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
